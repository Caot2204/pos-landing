---
import { Image } from "astro:assets";
const { icon, name, url } = Astro.props;
---

<style>
  .social-container {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    align-items: center;
  }

  a {
    text-decoration: none;
    color: black;
  }
</style>

<div class="social-container">
  <a href={url}><Image src={icon} alt={name} width={20} height={20} /></a>
</div>
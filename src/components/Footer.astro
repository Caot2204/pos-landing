---
import Attributions from "./Attributions.astro"
import Social from "./Social.astro";
import githubIcon from "../images/github-icon.png";
---

<style>
  .social-container {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 2rem;
  }

  .social-container > ul {
    flex: 0 0 auto;
    margin: 0;
    padding: 0;
  }

  .social-container > ul > li {
    list-style: none;
  }

  .social-container > :last-child {
    flex: 0 0 40%;
    max-width: 40%;
  }
</style>

<footer>
  <div class="social-container">
    <ul>
      <Social
        icon={githubIcon}
        name="Github"
        url="https://github.com/Caot2204/PosDesktop" />
    </ul>
    <Attributions />
  </div>
</footer>
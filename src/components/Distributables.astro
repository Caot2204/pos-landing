---
import logoWindows from "../images/logo-windows.png";
import logoLinux from "../images/logo-linux.png";
import { Image } from "astro:assets";
import DownloadButton from "./DownloadButton";
const { id } = Astro.props;

interface GitHubReleaseAsset {
  name: string;
  browser_download_url: string;
}

interface GitHubRelease {
  tag_name?: string;
  assets?: GitHubReleaseAsset[];
}

//const response = await fetch('https://api.github.com/repos/Caot2204/PosDesktop/releases/latest');
//const data = await response.json() as GitHubRelease;
const data: GitHubRelease = {
  tag_name: "v1.0.0",
  assets: [
    { name: "posdesktop-setup.exe", browser_download_url: "https://example.com/posdesktop-setup.exe" },
    { name: "posdesktop.AppImage", browser_download_url: "https://example.com/posdesktop.AppImage" }
  ]
};
const appVersion = data.tag_name || "latest";
const winAsset = data.assets?.find(asset  => asset.name.endsWith('.exe'))?.browser_download_url || "#";
const linuxAsset = data.assets?.find(asset => asset.name.endsWith('.AppImage'))?.browser_download_url || "#"; 
---

<style>
  .distributables-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-bottom: 50px;
    box-sizing: border-box;
    width: 100%;
  }

  .distributables-section > h1 {
    color: white;
  }

  .distributables-container {
    display: flex;
    flex-direction: row;
    gap: 50px;
    width: fit-content;
    box-sizing: border-box;
  }

  .distributable-item {
    display: flex;
    flex-direction: column;
    gap: 30px;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 250px;
    padding: 10px;
    background-color: aliceblue;
    border-radius: 10px;
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.1);
  }

  .distributable-text {
    font-size: 1.2rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .distributables-container {
      flex-direction: column;
      gap: 20px;
      width: calc(100% - 30px);
      margin: 0 15px;
    }
    .distributable-item {
      height: auto;
      gap: 20px;
      box-sizing: border-box;
    }
  }
</style>

<section id={id} class="distributables-section">
  <h1>Plataformas disponibles</h1>
  <div class="distributables-container">
    <div class="distributable-item">
      <Image src={logoWindows} alt="logo windows" width={50} height={50} />
      <p class="distributable-text">Windows (.exe)</p>
      <DownloadButton downloadUrl={winAsset} version={appVersion} />
    </div>
    <div class="distributable-item">
      <Image src={logoLinux} alt="logo linux" width={50} height={50} />
      <p class="distributable-text">Linux (.AppImage)</p>
      <DownloadButton downloadUrl={linuxAsset} version={appVersion} />
    </div>
  </div>
</section>

---
import { Image } from "astro:assets";
import ImageLink from "./ImageLink.astro";
import githubIcon from "../images/github-icon.png";
const { appLogo, appName } = Astro.props;
---

<style>
  .main-header {
    position: sticky;
    top: 0;
    color: black;
    z-index: 50;
    width: 100%;
    height: 50px;
    background-color: white;
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.1);
  }

  nav {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  .app-data {
    display: flex;
    flex-direction: row;
    gap: 10px;
    align-items: center;
    margin-left: 2em;
  }

  .button-header {
    width: 80px;
  }

  :global(.github-button) {
    margin-right: 2em;
  }
</style>

<header class="main-header">
  <nav>
    <div class="app-data">
      <Image src={appLogo} , alt={appName} width={20} height={20} />
      <p><strong>{appName}</strong></p>
    </div>
    <ImageLink
      extraClass="github-button"
      icon={githubIcon}
      altImage="Github"
      url="https://github.com/Caot2204/PosDesktop"
      width={20}
      height={20}
    />
  </nav>
</header>
